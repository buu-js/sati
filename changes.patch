-const app = createSati({
+export const app = createSati({
   middlewares: (m) => [
     // 1. Enable compression
     m.compress(),
@@ -38,15 +54,13 @@ const app = createSati({
     // 2. Inject security headers
     m.secureHeaders(),
     
-    // 3. Resolve and inject client IP address into context
-    m.ip({
-      getConnInfo
-    }),
+    // 3. Resolve and inject client IP address into context variable map
+    m.ip({ getConnInfo }),
     
-    // 4. Attach high-performance Pino logger
+    // 4. Attach high-performance Pino logger with contextual binding
     m.logger(),
     
