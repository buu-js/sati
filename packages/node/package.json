{
  "name": "@buujs/sati-node",
  "version": "0.1.2",
  "license": "MIT",
  "author": "Forte Zhuo",
  "repository": "github:buu-js/sati",
  "bin": {
    "pretty-log": "./bin/pretty-log.js"
  },
  "files": [
    "bin",
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./logger": {
      "import": {
        "types": "./dist/logger/index.d.ts",
        "default": "./dist/logger/index.js"
      },
      "require": {
        "types": "./dist/logger/index.d.cts",
        "default": "./dist/logger/index.cjs"
      }
    },
    "./shutdown": {
      "import": {
        "types": "./dist/shutdown/index.d.ts",
        "default": "./dist/shutdown/index.js"
      },
      "require": {
        "types": "./dist/shutdown/index.d.cts",
        "default": "./dist/shutdown/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "tsdx dev",
    "build": "tsdx build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsdx lint",
    "format": "tsdx format",
    "format:check": "tsdx format --check",
    "typecheck": "tsdx typecheck",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.20.1"
  },
  "peerDependencies": {
    "@buujs/sati": "workspace:*",
    "@buujs/sati-croner": "workspace:*"
  },
  "engines": {
    "node": ">=20"
  }
}
