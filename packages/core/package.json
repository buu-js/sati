{
  "name": "@buujs/sati",
  "version": "0.1.2",
  "license": "MIT",
  "author": "Forte Zhuo",
  "repository": "github:buu-js/sati",
  "bin": {
    "pretty-log": "./bin/pretty-log.js"
  },
  "files": [
    "dist",
    "bin"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./boot": {
      "import": {
        "types": "./dist/boot/index.d.ts",
        "default": "./dist/boot/index.js"
      },
      "require": {
        "types": "./dist/boot/index.d.cts",
        "default": "./dist/boot/index.cjs"
      }
    },
    "./logger": {
      "import": {
        "types": "./dist/logger/index.d.ts",
        "default": "./dist/logger/index.js"
      },
      "require": {
        "types": "./dist/logger/index.d.cts",
        "default": "./dist/logger/index.cjs"
      }
    },
    "./scheduler": {
      "import": {
        "types": "./dist/scheduler/index.d.ts"
      },
      "require": {
        "types": "./dist/scheduler/index.d.cts"
      }
    },
    "./shutdown": {
      "import": {
        "types": "./dist/shutdown/index.d.ts",
        "default": "./dist/shutdown/index.js"
      },
      "require": {
        "types": "./dist/shutdown/index.d.cts",
        "default": "./dist/shutdown/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "tsdx dev",
    "build": "tsdx build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsdx lint",
    "format": "tsdx format",
    "format:check": "tsdx format --check",
    "typecheck": "tsdx typecheck",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "hono-rate-limiter": "^0.5.3",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@buujs/sati-utils": "workspace:*"
  },
  "peerDependencies": {
    "hono": "^4.12.27"
  },
  "engines": {
    "node": ">=20"
  }
}
